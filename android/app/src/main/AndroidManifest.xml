<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:label="@string/app_name"
        android:supportsRtl="true">

        <!-- The full app: Now / 14-Day forecast + score breakdown (Jetpack Compose). -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@android:style/Theme.Material.Light.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- The home-screen widget. No launcher Activity is needed: you add the
             widget from the launcher's widget tray. -->
        <receiver
            android:name=".AcWidgetProvider"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.acwidget.ACTION_REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/ac_widget_info" />
        </receiver>

        <!-- Global app / comfort settings (thresholds + location). Launched from the
             app's gear icon. Not the widget's configure screen anymore. -->
        <activity
            android:name=".ConfigActivity"
            android:exported="false"
            android:label="AC / Windows settings"
            android:theme="@android:style/Theme.Material" />

        <!-- Widget-only settings (forecast length + opacity). Shown when the widget is
             added / reconfigured, and via long-press on the app's gear icon. -->
        <activity
            android:name=".WidgetSettingsActivity"
            android:exported="true"
            android:label="Widget settings"
            android:theme="@android:style/Theme.Material">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>
    </application>
</manifest>
