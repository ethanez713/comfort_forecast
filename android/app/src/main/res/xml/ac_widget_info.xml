<?xml version="1.0" encoding="utf-8"?>
<!-- Widget metadata. updatePeriodMillis is 0 because the OS minimum is 30 min and
     we drive refreshes ourselves with WorkManager (and on tap) instead. -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="110dp"
    android:minHeight="110dp"
    android:minResizeWidth="110dp"
    android:minResizeHeight="110dp"
    android:maxResizeWidth="600dp"
    android:maxResizeHeight="520dp"
    android:targetCellWidth="4"
    android:targetCellHeight="3"
    android:updatePeriodMillis="0"
    android:initialLayout="@layout/widget_ac"
    android:previewLayout="@layout/widget_ac"
    android:description="@string/widget_description"
    android:configure="com.acwidget.WidgetSettingsActivity"
    android:widgetFeatures="reconfigurable"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen" />
